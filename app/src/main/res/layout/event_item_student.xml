<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:flexbox="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardElevation="8dp"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvEventTitleStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Title"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvEventDescriptionStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Description"
            android:layout_marginTop="4dp"
            android:maxLines="3"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/btnSeeMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="See More"
            android:textColor="@color/purple_500"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvEventDateStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Date"
            android:layout_marginTop="4dp"
            android:textStyle="italic"/>

        <!-- Responsive radio buttons using Flexbox -->
        <!-- Title for the radio buttons -->
        <TextView
            android:id="@+id/tvResponseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Are you?"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <RadioGroup
            android:id="@+id/radioGroupResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:baselineAligned="false">

            <RadioButton
                android:id="@+id/rbInterested"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Interested"
                android:layout_marginBottom="4dp"/>

            <RadioButton
                android:id="@+id/rbNotInterested"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not Interested"
                android:layout_marginBottom="4dp"/>

            <RadioButton
                android:id="@+id/rbGoing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Going"/>
        </RadioGroup>



        <Button
            android:id="@+id/btnSubmitResponse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
